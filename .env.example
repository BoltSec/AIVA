# Copy to .env and fill in. Never commit the real .env.

# ---- The ONLY secret in the whole project ----
NVD_API_KEY=paste-your-rotated-nvd-key-here

# ---- Switch components from offline fixtures to live APIs ----
AIVA_INTEL_MODE=live          # AIVA: live | offline
DASH_OSV_MODE=live            # Dashboard: live | offline

# ---- Your downloaded CISA KEV catalog (optional but recommended) ----
# If set, AIVA reads this local file instead of re-downloading from CISA.
AIVA_KEV_FILE=config/known_exploited_vulnerabilities.json

# ---- AI agent (optional, FREE): tailored remediation + exec summary ----
# Pick a free provider and set its key. Gemini's free tier is most generous.
AIVA_LLM_PROVIDER=gemini          # gemini | groq | openrouter | ollama | openai
GEMINI_API_KEY=                   # free key from https://aistudio.google.com
# GROQ_API_KEY=                   # if AIVA_LLM_PROVIDER=groq (console.groq.com)
# OPENROUTER_API_KEY=             # if AIVA_LLM_PROVIDER=openrouter
# AIVA_LLM_MODEL=                 # optional model override

# ---- AI agent rate/cache tuning (free tier) ----
AIVA_LLM_RPM=12
AIVA_LLM_RETRIES=4
